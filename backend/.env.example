# ── Broker: Interactive Brokers / IBKR TWS or Gateway ─────────────────
# No API key is used for the normal IBKR socket API. Log in to TWS/Gateway,
# enable API → Socket Clients, then point the app at the local socket.
BROKER=ibkr
IBKR_HOST=127.0.0.1
# Paper Gateway: 4002. Paper TWS: 7497. Live Gateway: 4001. Live TWS: 7496.
IBKR_PORT=4002
IBKR_CLIENT_ID=11
# Optional: pin an account if TWS/Gateway exposes more than one.
IBKR_ACCOUNT=
# Keep paper until deliberately moving to live.
IBKR_TRADING_MODE=paper

# ── Safety gates ───────────────────────────────────────────────────────
# TRADING_ENABLED must be true for any order submission, including paper.
# LIVE_TRADING must also be true, with IBKR_TRADING_MODE=live and per-order
# confirmation, before any real-money order is allowed.
TRADING_ENABLED=false
PAPER_STARTING_CASH=100000
# Local app-only paper cash overlay; this does not deposit broker funds.
PAPER_CASH_ADJUSTMENT=0
LIVE_TRADING=false

# ── Risk parameters (defaults; editable in the UI/Settings) ────────────
MAX_POSITION_PCT=0.10        # max % of equity per position
MAX_TOTAL_EXPOSURE_PCT=0.80  # max % of equity invested at once
STOP_LOSS_PCT=0.05           # per-trade stop loss
TAKE_PROFIT_PCT=0.15         # per-trade take profit

# ── Optional: LLM sentiment backend ────────────────────────────────────
# Only used when the "Sentiment engine" setting is switched to "llm". It runs
# through the local Hermes CLI and uses the same ChatGPT/OpenAI subscription
# Hermes is authenticated with (no OpenAI API key). Leave the model blank to use
# Hermes' configured default, or pin one (e.g. gpt-5.5).
CHATGPT_SENTIMENT_MODEL=
HERMES_CLI=hermes

# ── App ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./stock_trader.db
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,NFLX,SPY
