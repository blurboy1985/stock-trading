# ── Alpaca API credentials ─────────────────────────────────────────────
# Create a FREE paper account at https://alpaca.markets and paste the keys
# from the dashboard. Paper keys work against the paper base URL below.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Paper trading endpoint (default). For LIVE trading switch to
# https://api.alpaca.markets AND set LIVE_TRADING=true (see safety gate).
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Safety: live trading kill switch ───────────────────────────────────
# MUST be true to allow real-money orders. Defaults to false (paper only).
LIVE_TRADING=false

# ── Risk parameters (defaults; editable in the UI/Settings) ────────────
MAX_POSITION_PCT=0.10        # max % of equity per position
MAX_TOTAL_EXPOSURE_PCT=0.80  # max % of equity invested at once
STOP_LOSS_PCT=0.05           # per-trade stop loss
TAKE_PROFIT_PCT=0.15         # per-trade take profit

# ── Optional: LLM sentiment backend ────────────────────────────────────
# Only used when the "Sentiment engine" setting is switched to "llm". It runs
# through your local Claude Code CLI subscription (no API key) — install the
# `claude` CLI, log in, and `pip install claude-agent-sdk`. The default lexicon
# engine needs none of this. Leave the model blank to use the CLI default, or
# pin one (e.g. claude-haiku-4-5 for speed).
ANTHROPIC_SENTIMENT_MODEL=

# ── App ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./stock_trader.db
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,NFLX,SPY
